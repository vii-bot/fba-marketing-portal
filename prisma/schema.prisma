generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Better Auth required models
// ──────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  emailVerified   Boolean   @default(false)
  image           String?
  role            String    @default("employee")
  department      String?
  jobTitle        String?
  profilePicture  String?
  bannerImage     String?
  discordUsername String?
  profileComplete Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  employee Employee?
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ──────────────────────────────────────────────────────────────
// HR — Employee
// ──────────────────────────────────────────────────────────────

model Employee {
  id              String    @id @default(cuid())
  userId          String?   @unique
  name            String
  email           String    @unique
  role            String
  department      String    @default("X")
  startDate       DateTime?
  status          String    @default("Active")
  notes           String?
  discordUsername String?
  contract        String?   // URL to uploaded PDF
  profilePicture  String?
  bannerImage     String?
  schedule        Json?
  access          Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user               User?               @relation(fields: [userId], references: [id])
  strikes            Strike[]
  attendanceRequests AttendanceRequest[]
  employeeRequests   EmployeeRequest[]
  tasks              Task[]
  inviteToken        InviteToken?
}

// ──────────────────────────────────────────────────────────────
// SSO Invite System
// ──────────────────────────────────────────────────────────────

model InviteToken {
  id         String    @id @default(cuid())
  token      String    @unique
  email      String    @unique
  employeeId String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────
// Strike System
// ──────────────────────────────────────────────────────────────

model Strike {
  id           String   @id @default(cuid())
  strikeCode   String   @unique
  name         String
  email        String
  role         String
  department   String   @default("X")
  type         String
  level        String
  incidentDate DateTime
  submitter    String
  reason       String
  impact       String?
  action       String?
  evidence     String?
  sopReference String?  // SOP ID referenced
  status       String   @default("Active")
  notes        String?
  requireAck   Boolean  @default(false)
  quarter      String
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  appeal     Appeal?
}

model Appeal {
  id          String   @id @default(cuid())
  strikeId    String   @unique
  email       String
  explanation String
  evidence    String?
  status      String   @default("Pending")
  reviewer    String?
  reviewNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  strike Strike @relation(fields: [strikeId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────────────────────
// Attendance
// ──────────────────────────────────────────────────────────────

model AttendanceRequest {
  id           String    @id @default(cuid())
  requestCode  String    @unique
  type         String
  name         String
  email        String
  role         String?
  department   String    @default("X")
  date         DateTime
  hours        Float?
  reason       String
  tasks        String?
  deliverables String?
  coverage     String?
  codes        String?
  notes        String?
  makeupDate   DateTime?
  missedDate   DateTime?
  leaveType    String?
  endDate      DateTime?
  manager      String?
  status       String    @default("Pending")
  reviewer     String?
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
}

// Generic employee-facing request system (bugs.md Phase 5). The `type`
// field is open-ended — only the types listed in lib/utils.ts'
// ACTIVE_REQUEST_TYPES are selectable when submitting new requests, but
// the schema itself does not constrain `type` so future request types
// (Payslip, Leave, HR, Payroll, Equipment, etc.) can be enabled later
// without a migration.
model EmployeeRequest {
  id          String    @id @default(cuid())
  requestCode String    @unique
  type        String
  name        String
  email       String
  role        String?
  department  String    @default("X")
  reason      String
  dateNeeded  DateTime?
  notes       String?
  status      String    @default("Pending")
  reviewer    String?
  reviewNotes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
}

// FBA Contractor Change Request — internal replacement for the Google Form
// (bugs.md Phase 6). Type-specific fields live in `details` (JSON);
// fields needed for the admin dashboard table are hoisted to top-level
// columns so they're directly queryable/sortable regardless of requestType.
model ContractorChangeRequest {
  id                    String    @id @default(cuid())
  requestCode           String    @unique
  requesterEmail        String
  requesterName         String
  department            String
  requestType           String
  contractorName        String?
  effectiveDate         DateTime? // Last Working Day | Effective Date | Start Date, depending on requestType
  effectiveDateSelected DateTime? // raw date selected before pay-period adjustment (Compensation Adjustment only)
  compensationType      String?
  compensationAmount    Float?
  details               Json
  status                String    @default("Pending")
  reviewer              String?
  reviewNotes           String?
  statusHistory         Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ──────────────────────────────────────────────────────────────
// Taskboard / Time Tracking (bugs.md Phase 4)
// ──────────────────────────────────────────────────────────────

// Daily task log for time tracking. `date` is the employee's local "shift
// day" (stored at UTC midnight) so the taskboard and end-of-shift export
// line up with what the employee sees regardless of server timezone.
// `startTime`/`finishTime`/`totalMinutes` are set automatically as `status`
// moves Pending -> In Progress -> Finished (see /api/tasks).
model Task {
  id           String    @id @default(cuid())
  email        String
  name         String
  department   String    @default("X")
  date         DateTime
  taskName     String
  category     String
  notes        String?
  status       String    @default("Pending") // Pending | In Progress | Finished
  startTime    DateTime?
  finishTime   DateTime?
  totalMinutes Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
}

// ──────────────────────────────────────────────────────────────
// Creator Management
// ──────────────────────────────────────────────────────────────

model Creator {
  id                  String   @id @default(cuid())
  creatorCode         String   @unique
  creatorName         String
  status              String   @default("Active")
  priority            String   @default("Medium")
  needsMedia          Boolean  @default(false)
  needsReview         Boolean  @default(false)
  assignedPageRunners String[]
  uploadsFolder       String?
  mediaFolder         String?
  signedPlatforms     String[] @default([])
  overview            String?
  niche               Json?
  assets              Json?
  accounts            Json?
  strategy            Json?
  archived            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  highlights     Highlight[]
  teamNotes      TeamNote[]
  creatorReports CreatorReport[]
}

model Highlight {
  id              String   @id @default(cuid())
  creatorId       String
  platform        String   @default("X")
  accountUsername String?
  postLink        String?
  likes           Int      @default(0)
  views           Int      @default(0)
  comments        Int      @default(0)
  reposts         Int      @default(0)
  bookmarks       Int      @default(0)
  notes           String?
  submittedBy     String?
  createdAt       DateTime @default(now())

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

// Team Notes (bugs.md Phase 11) — a note log / activity thread attached to
// each creator profile. Separate from Creator.strategy.notes (the legacy
// single free-text field, kept for historical display).
model TeamNote {
  id          String    @id @default(cuid())
  creatorId   String
  content     String    @db.Text
  authorEmail String
  authorName  String
  editedAt    DateTime?
  createdAt   DateTime  @default(now())

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

// Creator Reports (bugs.md Phase 10) — weekly per-account reports submitted
// by Page Runners, reviewed by Account Managers, and rolled up under each
// creator. `creatorCode`/`creatorName`/`department` are hoisted from Creator
// at submission time so the admin dashboard can filter/export without joins.
model CreatorReport {
  id              String    @id @default(cuid())
  creatorId       String
  creatorCode     String
  creatorName     String
  accountUsername String
  department      String
  reportType      String // Internal Report | Creator Report
  status          String    @default("Submitted") // Draft | Submitted | Needs Revision | Approved for Creator | Sent to Creator | Archived
  followerCount   Int? // Instagram only — not the primary signal for X/Reddit
  followerChange  String?
  summary         String?   @db.Text // Performance Summary
  highlights      Json? // Top Highlights — shape varies by platform, see lib/utils.ts HIGHLIGHT_FIELDS
  metrics         Json? // Instagram-only engagement metrics: { reach, likes, comments, shares, saves, storyViews }
  trafficNotes    String?   @db.Text // Traffic / Conversion Notes
  whatsWorking    String?   @db.Text
  whatsNotWorking String?   @db.Text
  needsTesting    String?   @db.Text // What Needs Testing
  actionItems     String?   @db.Text
  recommendedFocus String?  @db.Text // Creator Report only
  additionalNotes String?   @db.Text
  links           Json? // string[]
  relayed         Boolean   @default(false)
  reviewerNotes   String?   @db.Text
  submittedBy     String
  submittedByName String
  submittedAt     DateTime  @default(now())
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

// Tracks which creator/account/week combinations have already had a
// compliance strike issued for a missing Mon-Wed Creator Report, so the
// admin-triggered "Run Weekly Compliance Check" doesn't double-strike on
// repeat clicks.
model ComplianceStrikeLog {
  id              String   @id @default(cuid())
  creatorId       String
  accountUsername String
  weekStart       DateTime
  strikeId        String?
  createdAt       DateTime @default(now())

  @@unique([creatorId, accountUsername, weekStart])
}

// ──────────────────────────────────────────────────────────────
// LMS — SOP Management
// ──────────────────────────────────────────────────────────────

model SOP {
  id               String   @id @default(cuid())
  title            String
  category         String
  content          String   @db.Text
  contentType      String   @default("SOP") // SOP | Course
  tier             String   // Introductory | Intermediate | Advanced | Upskill
  version          Int      @default(1)
  isRequired       Boolean  @default(true)
  isArchived       Boolean  @default(false)
  department       String   @default("All Departments")
  roles            String[] @default([]) // empty = visible to all roles in department
  status           String   @default("Published") // Draft | Published
  blocks           Json?    // structured Notion-style block content; null = legacy text-only SOP
  estimatedMinutes Int?

  // Acknowledgement deadline (bugs.md Phase 3)
  deadlineType  String    @default("None") // None | Fixed | Relative
  deadlineDate  DateTime?                   // used when deadlineType = Fixed
  deadlineDays  Int?                        // used when deadlineType = Relative
  deadlineBasis String?                     // Publish | Assignment — used when deadlineType = Relative

  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  acknowledgements SOPAcknowledgement[]
  exemptions       SOPExemption[]
  assessment       Assessment?
}

// Per-employee bypass of a SOP's acknowledgement deadline (bugs.md Phase 3) —
// e.g. for new hires who need more time. Does not affect other employees.
model SOPExemption {
  id        String   @id @default(cuid())
  sopId     String
  email     String
  reason    String?
  grantedBy String
  createdAt DateTime @default(now())

  sop SOP @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@unique([sopId, email])
}

model SOPAcknowledgement {
  id             String   @id @default(cuid())
  sopId          String
  email          String
  version        Int
  acknowledgedAt DateTime @default(now())

  sop SOP @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@unique([sopId, email, version])
}

// Tracks "viewed" distinctly from "acknowledged" (bugs.md §6) without disturbing
// the acknowledgement model's existing semantics (a row there always = acknowledged).
model SOPView {
  id        String   @id @default(cuid())
  sopId     String
  email     String
  viewedAt  DateTime @default(now())

  @@unique([sopId, email])
}

// ──────────────────────────────────────────────────────────────
// LMS — Module Acknowledgement (training pages)
// ──────────────────────────────────────────────────────────────

model ModuleAcknowledgement {
  id             String   @id @default(cuid())
  email          String
  moduleId       String
  version        Int      @default(1)
  acknowledgedAt DateTime @default(now())

  @@unique([email, moduleId])
}

// ──────────────────────────────────────────────────────────────
// LMS — Assessments
// ──────────────────────────────────────────────────────────────

model Assessment {
  id           String   @id @default(cuid())
  sopId        String?  @unique
  moduleId     String?
  title        String
  tier         String
  passingScore Int      @default(70)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sop       SOP?       @relation(fields: [sopId], references: [id])
  questions Question[]
  attempts  AssessmentAttempt[]
}

model Question {
  id            String  @id @default(cuid())
  assessmentId  String
  type          String  // MultipleChoice | TrueFalse | Scenario | ShortAnswer
  text          String
  options       Json?   // ["A", "B", "C", "D"] for MCQ
  correctAnswer String? // null for ShortAnswer

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentAttempt {
  id           String   @id @default(cuid())
  assessmentId String
  email        String
  answers      Json
  score        Int
  passed       Boolean
  completedAt  DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id])
}

// ──────────────────────────────────────────────────────────────
// Audit Log
// ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actor      String   // email of who performed the action
  action     String   // e.g. "strike.create", "sop.update", "attendance.approve"
  entityType String   // "Strike" | "SOP" | "AttendanceRequest" | etc.
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  email     String
  type      String   // NewSOP | SOPUpdated | AssessmentRequired | CertificationEarned | StrikeIssued
  message   String
  href      String?
  metadata  Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// Legacy LMS (kept for backward-compat, superseded by ModuleAcknowledgement)
// ──────────────────────────────────────────────────────────────

model LearningProgress {
  id          String   @id @default(cuid())
  email       String
  pageId      String
  completedAt DateTime @default(now())

  @@unique([email, pageId])
}

model Quiz {
  id          String   @id @default(cuid())
  quizId      String   @unique
  milestoneId String
  questions   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results QuizResult[]
}

model QuizResult {
  id            String   @id @default(cuid())
  resultId      String   @unique
  quizId        String
  milestoneId   String
  employeeEmail String
  score         Float
  answers       Json?
  submittedAt   DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [quizId])
}

model PracticalMilestone {
  id            String   @id @default(cuid())
  practicalId   String   @unique
  employeeEmail String
  milestoneId   String
  status        String   @default("Not Started")
  notes         String?
  reviewer      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeEmail, milestoneId])
}

model Readiness {
  id            String   @id @default(cuid())
  readinessId   String   @unique
  employeeEmail String
  milestoneId   String
  status        String   @default("Not Started")
  notes         String?
  reviewer      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([employeeEmail, milestoneId])
}

// ──────────────────────────────────────────────────────────────
// Internal Documentation CMS (bugs.md Phase 13)
// ──────────────────────────────────────────────────────────────

// Admin/developer-facing documentation pages — separate from the
// employee-facing SOP/Resource Portal system, but reuses the same
// Notion-style block content format (lib/sop-blocks.ts) via `blocks`.
// `priority`/`itemStatus`/`changeType`/`featureArea`/`targetDate` are hoisted,
// category-specific fields used by the Changelog, Known Issues, and Roadmap
// categories so the CMS can filter/sort without parsing blocks.
model DocPage {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  category   String // App Overview | System Architecture | Authentication & Access | Feature Documentation | Workflow Documentation | Database & Data Models | API & Backend Notes | Changelog | Known Issues | Roadmap
  tags       String[] @default([])
  status     String   @default("Draft") // Draft | Published | Archived
  visibility String[] @default([]) // role names granted read access in addition to Admin/Executive; empty = Admin/Executive only

  blocks Json? // SOPBlock[] — main content body (lib/sop-blocks.ts)

  // Category-specific structured fields
  priority    String? // Low | Medium | High | Urgent (Known Issues, Roadmap)
  itemStatus  String? // Open | In Progress | Resolved (Known Issues) or Planned | In Progress | Completed | On Hold (Roadmap)
  changeType  String? // Added | Changed | Fixed | Removed | Planned (Changelog)
  featureArea String? // affected feature/module (Changelog, Known Issues, Roadmap, Feature Documentation)
  targetDate  DateTime? // optional target timeline (Roadmap)

  createdBy     String
  createdByName String
  updatedBy     String?
  updatedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
}
